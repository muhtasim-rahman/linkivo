{
  "name": "Linkivo",
  "shortName": "Linkivo",
  "tagline": "Save, Organize & Discover Links Smarter",
  "description": "Linkivo is a smart link management web app that lets you save, organize, and randomly discover links — imported from text, PDF, bookmarks, HTML, JSON and more.",
  "version": "v1.4.4",
  "buildDate": "2026-03-31",
  "author": "Linkivo",
  "url": "https://linkivo.web.app",
  "repoUrl": "https://github.com/yourusername/linkivo",
  "theme": {
    "primary": "#3b82f6",
    "secondary": "#22d3ee",
    "accent": "blue"
  },
  "features": [
    "Import links from 10+ file formats",
    "Folder-based organization with PIN lock",
    "Smart random link discovery",
    "Point-based link weighting system",
    "Embedded link preview without leaving the app",
    "Cross-device sync via Firebase",
    "Works offline as a PWA",
    "Export to JSON, CSV, PDF, Markdown, Bookmarks",
    "Full light & dark mode support",
    "App lock with PIN",
    "Accent theme colors",
    "Global search across all folders"
  ],
  "supportedImportFormats": [
    "txt",
    "pdf",
    "html",
    "json",
    "csv",
    "zip",
    "png",
    "jpg",
    "jpeg",
    "webp",
    "bookmarks",
    "htm",
    "md"
  ],
  "exportFormats": [
    "json",
    "csv",
    "pdf",
    "html",
    "markdown",
    "print"
  ],
  "pointSystem": {
    "basePoints": 100,
    "likeBonus": 50,
    "dislikePenalty": -40,
    "favouriteBonus": 100,
    "blockedMultiplier": 0
  },
  "recycleBinDays": 30,
  "historyMaxItems": 500,
